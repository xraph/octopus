# EditorConfig helps maintain consistent coding styles
# https://editorconfig.org

root = true

# Default settings for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Rust source files
[*.rs]
indent_size = 4
max_line_length = 100

# TOML files (Cargo.toml, config files)
[*.toml]
indent_size = 4

# YAML files (configs, CI)
[*.{yml,yaml}]
indent_size = 2

# JSON files
[*.json]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# Shell scripts
[*.sh]
indent_size = 2

# Makefile
[{Makefile,*.mk}]
indent_style = tab

# Justfile
[Justfile]
indent_style = space
indent_size = 4

# HTML templates
[*.html]
indent_size = 2

# JavaScript/TypeScript
[*.{js,ts,jsx,tsx}]
indent_size = 2

# CSS/SCSS
[*.{css,scss}]
indent_size = 2

# Configuration files
[.{prettierrc,stylelintrc,eslintrc}]
indent_size = 2

# Git files
[.git*]
indent_size = 2
