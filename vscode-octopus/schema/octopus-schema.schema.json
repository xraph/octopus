{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/xraph/octopus/schema/octopus-schema.schema.json",
  "title": "Octopus Schema Intermediate Format",
  "description": "JSON Schema for .octopus.json files - the intermediate representation used by the Octopus code generator. Describes services, their operations, and shared type definitions.",
  "type": "object",
  "required": ["version", "services"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "version": {
      "type": "string",
      "description": "Schema version",
      "enum": ["1.0.0", "1.1.0"],
      "default": "1.0.0"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when this schema was generated",
      "format": "date-time"
    },
    "services": {
      "type": "object",
      "description": "Map of service name to service definition",
      "additionalProperties": {
        "$ref": "#/definitions/ServiceDefinition"
      }
    },
    "types": {
      "type": "object",
      "description": "Shared type definitions referenced by service operations",
      "additionalProperties": {
        "$ref": "#/definitions/TypeDefinition"
      }
    }
  },
  "definitions": {
    "ServiceDefinition": {
      "type": "object",
      "description": "A service with its base path, upstream, auth settings, and operations",
      "required": ["operations"],
      "additionalProperties": false,
      "properties": {
        "base_path": {
          "type": "string",
          "description": "Base path prefix for all operations in this service",
          "examples": ["/api/users", "/v1/billing"]
        },
        "upstream": {
          "type": "string",
          "description": "Upstream name this service maps to"
        },
        "auth": {
          "type": "object",
          "description": "Default auth settings for all operations in this service",
          "additionalProperties": false,
          "properties": {
            "provider": {
              "type": "string",
              "description": "Auth provider name"
            },
            "scopes": {
              "type": "array",
              "description": "Required scopes",
              "items": { "type": "string" }
            },
            "skip": {
              "type": "boolean",
              "description": "Skip auth for this service",
              "default": false
            }
          }
        },
        "operations": {
          "type": "object",
          "description": "Map of operation ID to operation definition",
          "additionalProperties": {
            "$ref": "#/definitions/OperationDefinition"
          }
        }
      }
    },
    "OperationDefinition": {
      "type": "object",
      "description": "An API operation (endpoint)",
      "required": ["method", "path"],
      "additionalProperties": false,
      "properties": {
        "method": {
          "type": "string",
          "description": "HTTP method",
          "enum": ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS", "HEAD"]
        },
        "path": {
          "type": "string",
          "description": "Path relative to service base_path",
          "examples": ["/{id}", "/search", "/"]
        },
        "summary": {
          "type": "string",
          "description": "Short summary of the operation"
        },
        "description": {
          "type": "string",
          "description": "Detailed description"
        },
        "tags": {
          "type": "array",
          "description": "Tags for grouping",
          "items": { "type": "string" }
        },
        "parameters": {
          "type": "array",
          "description": "Path, query, and header parameters",
          "items": {
            "$ref": "#/definitions/ParameterDefinition"
          }
        },
        "request_body": {
          "$ref": "#/definitions/RequestBodyDefinition"
        },
        "responses": {
          "type": "object",
          "description": "Map of status code to response definition",
          "additionalProperties": {
            "$ref": "#/definitions/ResponseDefinition"
          }
        },
        "auth": {
          "type": "object",
          "description": "Per-operation auth override",
          "properties": {
            "provider": { "type": "string" },
            "scopes": { "type": "array", "items": { "type": "string" } },
            "skip": { "type": "boolean" }
          }
        },
        "deprecated": {
          "type": "boolean",
          "description": "Whether this operation is deprecated",
          "default": false
        }
      }
    },
    "ParameterDefinition": {
      "type": "object",
      "description": "API parameter",
      "required": ["name", "in"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Parameter name"
        },
        "in": {
          "type": "string",
          "description": "Parameter location",
          "enum": ["path", "query", "header", "cookie"]
        },
        "required": {
          "type": "boolean",
          "description": "Whether the parameter is required",
          "default": false
        },
        "description": {
          "type": "string"
        },
        "schema": {
          "description": "JSON Schema for the parameter value",
          "type": "object"
        }
      }
    },
    "RequestBodyDefinition": {
      "type": "object",
      "description": "Request body definition",
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "boolean",
          "default": false
        },
        "content_type": {
          "type": "string",
          "description": "Content type",
          "default": "application/json",
          "examples": ["application/json", "multipart/form-data"]
        },
        "schema": {
          "description": "JSON Schema for the request body",
          "type": "object"
        }
      }
    },
    "ResponseDefinition": {
      "type": "object",
      "description": "Response definition for a status code",
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string"
        },
        "content_type": {
          "type": "string",
          "default": "application/json"
        },
        "schema": {
          "description": "JSON Schema for the response body",
          "type": "object"
        },
        "headers": {
          "type": "object",
          "description": "Response headers",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "schema": { "type": "object" }
            }
          }
        }
      }
    },
    "TypeDefinition": {
      "type": "object",
      "description": "Shared type definition (JSON Schema subset)",
      "properties": {
        "type": {
          "type": "string",
          "description": "JSON Schema type",
          "enum": ["object", "array", "string", "number", "integer", "boolean", "null"]
        },
        "description": { "type": "string" },
        "properties": {
          "type": "object",
          "additionalProperties": { "type": "object" }
        },
        "required": {
          "type": "array",
          "items": { "type": "string" }
        },
        "items": {
          "type": "object",
          "description": "Schema for array items"
        },
        "enum": {
          "type": "array",
          "description": "Allowed values"
        },
        "format": {
          "type": "string",
          "description": "Format hint (e.g. date-time, email, uuid)"
        },
        "additionalProperties": {},
        "$ref": {
          "type": "string",
          "description": "Reference to another type definition"
        }
      }
    }
  }
}
